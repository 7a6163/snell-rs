# snell-rs Docker Compose configuration.
# Copy to .env and edit. Never commit .env (already in .gitignore).

# ── Required ──────────────────────────────────────────────────────────────────

# Pre-shared key. Must be at least 16 characters. Server exits if missing.
# Generate one:  openssl rand -base64 32
PSK=replace-me-with-at-least-16-chars

# ── Optional ──────────────────────────────────────────────────────────────────

# Public host port to bind. Container always listens on 6180 internally.
# PORT=6180

# Container name shown in `docker ps`.
# CONTAINER_NAME=snell

# Image tag to pull from ghcr.io. Pin a version in production.
# TAG=latest          # or v5.0.0, 5.0, 5

# Enable QUIC proxy mode (opens UDP listener on the same port).
# QUIC=1

# Bind outgoing connections to a specific network interface.
# Requires CAP_NET_RAW (already granted in compose).
# EGRESS_INTERFACE=eth0

# Refuse to proxy to loopback / private / reserved addresses.
# Default off — snell is a proxy tool and LAN access is a legitimate use.
# Enable only on internet-exposed VPS deployments where you want
# SSRF hardening against a leaked PSK.
# BLOCK_PRIVATE_TARGETS=1

# Server-side TCP Fast Open (RFC 7413). Defaults to ON, matching the
# official snell-server. Set to 0 to disable. The effective state still
# requires the kernel sysctl to allow server cookies
# (Linux: net.ipv4.tcp_fastopen bit 2; macOS: net.inet.tcp.fastopen bit 2).
# When using Docker, the host sysctl applies — the container can't change it.
# TCP_FASTOPEN=0

# Opt outbound CONNECT sockets into client-side TFO. Off by default —
# many destinations don't speak TFO. Linux >= 4.11 only; no-op on macOS.
# TCP_FASTOPEN_OUT=1
